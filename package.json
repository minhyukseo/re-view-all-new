{
  "name": "review-fast",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix web run dev",
    "dev:api": "npm --prefix server run dev",
    "dev:edge": "npx wrangler dev --config edge-worker/wrangler.toml",
    "build": "npm run build:web",
    "build:web": "npm --prefix web run build",
    "build:api": "npm --prefix server run deploy -- --dry-run",
    "preview:web": "npm --prefix web run preview",
    "deploy:web": "npm --prefix web run deploy",
    "start:web": "npm --prefix web run start",
    "cf:api:dev": "npm --prefix server run dev",
    "cf:api:deploy": "npm --prefix server run deploy",
    "cf:edge:deploy": "npx wrangler deploy --config edge-worker/wrangler.toml",
    "cloudflare:api:deploy": "npm run cf:api:deploy",
    "cf:api:tail": "cd server && npx wrangler tail",
    "cf:api:tail:readsync": "bash scripts/cf-readsync-tail.sh",
    "cf:readsync:smoke": "bash scripts/cf-readsync-smoke.sh",
    "cf:readsync:report": "node scripts/cf-readsync-log-report.js",
    "cf:ingest:run": "node server/scripts/push_worker_cache.js",
    "cf:verify:run": "node server/scripts/verify_new_items.js",
    "cf:sync:pipeline": "node server/scripts/sync_pipeline.js",
    "cloudflare:ingest:run": "npm run cf:ingest:run",
    "deploy:cloudflare": "./scripts/deploy-cloudflare.sh",
    "server:dev": "npm run dev:api",
    "widgets:refresh": "node server/scripts/build_rail_widgets.js",
    "backtest": "node server/scripts/backtest_adapters.js",
    "patch:flags": "node server/scripts/patch_feed_flags.js",
    "patch:flags:dry": "DRY_RUN=1 node server/scripts/patch_feed_flags.js",
    "patch:text": "node server/scripts/patch_text_items.js",
    "patch:text:dry": "DRY_RUN=1 node server/scripts/patch_text_items.js"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "4.68.1"
  }
}
